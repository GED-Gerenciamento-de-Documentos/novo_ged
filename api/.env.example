# ================================
# GED API — Variáveis de Ambiente
# ================================

# App
APP_NAME="GED API"
APP_VERSION="1.0.0"
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ================================
# PostgreSQL — Metadados GED
# ================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ged_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=ged_metadata
DATABASE_URL=postgresql+asyncpg://ged_user:your_postgres_password_here@localhost:5432/ged_metadata

# ================================
# Oracle 11g — Banco Legado (Read-Only)
# ================================
ORACLE_HOST=your_oracle_host_here
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=your_service_name_here
ORACLE_USER=your_oracle_user_here
ORACLE_PASSWORD=your_oracle_password_here
ORACLE_DSN=your_oracle_host_here:1521/your_service_name_here

# ================================
# Redis — Cache & Token Blacklist
# ================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_URL=redis://:your_redis_password_here@localhost:6379/0

# ================================
# JWT
# ================================
JWT_SECRET_KEY=your_super_secret_jwt_key_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ================================
# Segurança — LGPD (criptografia CPF)
# ================================
ENCRYPTION_KEY=your_base64_encoded_encryption_key_32_bytes

# ================================
# Storage NFS (Legado — Somente Leitura)
# ================================
NFS_MOUNT_PATH=/mnt/nfs/documentos
NFS_LEGACY_BASE_PATH=/mnt/nfs/documentos/legado

# ================================
# Storage Cloud (stub ativo por padrão)
# ================================
CLOUD_STORAGE_PROVIDER=stub

# Para AWS S3 (descomente e configure quando necessário):
# CLOUD_STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_REGION=sa-east-1
# S3_BUCKET_NAME=your_bucket_name_here
# S3_BUCKET_GLACIER=your_glacier_bucket_name_here

# Para Azure Blob (descomente e configure quando necessário):
# CLOUD_STORAGE_PROVIDER=azure
# AZURE_CONNECTION_STRING=your_connection_string_here
# AZURE_CONTAINER_NAME=your_container_name_here

# ================================
# Upload
# ================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=jpg,jpeg,jbig2,jb2,pdf,png,tiff,tif

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=minute

# ================================
# CORS
# ================================
CORS_ORIGINS=http://localhost:5174,http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
5823